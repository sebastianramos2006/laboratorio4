{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { 
      "source": "/tareas(.*)", 
      "destination": "/api/index.py" 
    },
    { 
      "source": "/docs(.*)", 
      "destination": "/api/index.py" 
    },
    { 
      "source": "/openapi.json", 
      "destination": "/api/index.py" 
    }
  ]
}