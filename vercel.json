{
  "version": 2,
  "builds": [
    {
      "src": "api/tareas.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/tareas/(.*)",
      "dest": "api/tareas.py"
    },
    {
      "src": "/api/tareas",
      "dest": "api/tareas.py"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
